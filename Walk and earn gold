<script>
// =============================================================
//  HEALTH IS WEALTH v4.0
//  UPI: bonagirispinoj-1@oksbi | Unlock: \u20b91,999 | \u20b92/km
//  KM Cap: 150 | Ref: \u20b9300 + 300 KM | Prizes: Car/Gold/Scooty
// =============================================================

const FB_CONFIG = {
  apiKey: "AIzaSyBIebPXVjzVBZl380ZCELg2LUSCLr-6QrE",
  authDomain: "neurocoin-ntc.firebaseapp.com",
  databaseURL: "https://neurocoin-ntc-default-rtdb.firebaseio.com",
  projectId: "neurocoin-ntc",
  storageBucket: "neurocoin-ntc.firebasestorage.app",
  messagingSenderId: "1040732555800",
  appId: "1:1040732555800:web:55e63b5ff81781c6b1916d",
  measurementId: "G-6X8T0YQTQ3"
};

const ADMIN_EMAIL    = "bonagirispinoj@gmail.com";
const PLATFORM_UPI   = "bonagirispinoj-1@oksbi";
const GPS_PRICE      = 1999;
const EARN_PER_KM    = 2;        // \u20b92 per km
const REF_BONUS_CASH = 300;      // \u20b9300 per referral
const REF_BONUS_KM   = 300;      // +300 km per referral
const BASE_KM_LIMIT  = 150;      // 150 km base cap
const MIN_WITHDRAW   = 100;

let db, auth, currentUser = null;
let S = { wallet:0, totalKm:0, todayKm:0, kmLimit:BASE_KM_LIMIT, referralCount:0, gpsUnlocked:false, refCode:"", upiId:"", name:"" };

// GPS state
let gpsWatchId = null, gpsLastPos = null, gpsLastTimestamp = 0;
let gpsSessionKm = 0, gpsPendingKm = 0;
let gpsRunning = false, gpsPaused = false;

// Share link cache
let currentShareLink = "";

// ===== INIT =====
try {
  firebase.initializeApp(FB_CONFIG);
  auth = firebase.auth();
  db   = firebase.firestore();
} catch(e){ console.error("Firebase init:", e); }

// Pre-fill referral code from URL
const urlParams  = new URLSearchParams(location.search);
const urlRefCode = urlParams.get("ref") || "";
if(urlRefCode){ const r = document.getElementById("regRef"); if(r) r.value = urlRefCode; }

// ===== AUTH STATE =====
auth.onAuthStateChanged(async (user) => {
  document.getElementById("splash").style.display = "none";
  if(user){
    currentUser = user;
    if(user.email === ADMIN_EMAIL){
      showScreen("admin");
      await initializeAdminDashboard();
    } else {
      showScreen("user");
      await loadUserData();
    }
  } else {
    showScreen("auth");
  }
});

// ===== SCREEN SWITCHER =====
function showScreen(screen){
  document.getElementById("authScreen").classList.add("hidden");
  document.getElementById("userApp").style.display = "none";
  document.getElementById("bnav").classList.add("hidden");
  document.getElementById("adminApp").classList.add("hidden");
  if(screen === "auth")  document.getElementById("authScreen").classList.remove("hidden");
  if(screen === "user"){
    document.getElementById("userApp").style.display = "flex";
    document.getElementById("bnav").classList.remove("hidden");
  }
  if(screen === "admin") document.getElementById("adminApp").classList.remove("hidden");
}

// ===== TAB SWITCHER =====
function switchTab(tabId){
  document.querySelectorAll(".tab-content").forEach(t => t.classList.remove("active"));
  document.querySelectorAll(".bnav-item").forEach(b => b.classList.remove("active"));
  document.getElementById(tabId).classList.add("active");
  const nb = document.getElementById("nav-" + tabId);
  if(nb) nb.classList.add("active");
  if(tabId === "tabHistory")     loadHistory();
  if(tabId === "tabLeaderboard") loadLeaderboard();
}

// ===== AUTH TABS =====
function switchAuthTab(tab){
  document.querySelectorAll(".auth-tab").forEach(t => t.classList.remove("active"));
  document.getElementById("loginForm").classList.add("hidden");
  document.getElementById("registerForm").classList.add("hidden");
  if(tab === "login"){
    document.querySelectorAll(".auth-tab")[0].classList.add("active");
    document.getElementById("loginForm").classList.remove("hidden");
  } else {
    document.querySelectorAll(".auth-tab")[1].classList.add("active");
    document.getElementById("registerForm").classList.remove("hidden");
  }
}

// ===== REGISTER =====
async function doRegister(){
  const name  = document.getElementById("regName").value.trim();
  const email = document.getElementById("regEmail").value.trim();
  const pass  = document.getElementById("regPass").value;
  const upi   = document.getElementById("regUpi").value.trim();
  const refBy = document.getElementById("regRef").value.trim().toUpperCase();

  if(!name||!email||!pass||pass.length<6)
    return showToast("\u26a0 Fill all fields (password min 6 chars)");

  try {
    const cred = await auth.createUserWithEmailAndPassword(email, pass);
    const uid  = cred.user.uid;
    const code = await generateUniqueRefCode();

    await db.collection("users").doc(uid).set({
      name, email, upiId: upi||"", refCode: code,
      refBy: refBy||null, referralCount: 0,
      wallet: 0, balance: 0, totalKm: 0, todayKm: 0,
      kmLimit: BASE_KM_LIMIT, gpsUnlocked: false,
      createdAt: firebase.firestore.FieldValue.serverTimestamp(),
      lastSeen:  firebase.firestore.FieldValue.serverTimestamp()
    });

    // Credit referrer
    if(refBy){
      const refSnap = await db.collection("users").where("refCode","==",refBy).get();
      if(!refSnap.empty){
        const refDoc = refSnap.docs[0];
        await db.collection("users").doc(refDoc.id).update({
          referralCount: firebase.firestore.FieldValue.increment(1),
          kmLimit:  firebase.firestore.FieldValue.increment(REF_BONUS_KM),
          wallet:   firebase.firestore.FieldValue.increment(REF_BONUS_CASH),
          balance:  firebase.firestore.FieldValue.increment(REF_BONUS_CASH)
        });
        await db.collection("km_logs").add({
          uid: refDoc.id, type: "referral", earned: REF_BONUS_CASH,
          kmBonus: REF_BONUS_KM, referredEmail: email,
          date: todayStr(), ts: firebase.firestore.FieldValue.serverTimestamp()
        });
      }
    }
    showToast("\u2705 Account created! Welcome, " + name);
  } catch(e){ showToast("\u274c " + (e.message||"Registration failed")); }
}

// ===== LOGIN =====
async function doLogin(){
  const email = document.getElementById("loginEmail").value.trim();
  const pass  = document.getElementById("loginPass").value;
  if(!email||!pass) return showToast("\u26a0 Enter email & password");
  try {
    await auth.signInWithEmailAndPassword(email, pass);
  } catch(e){ showToast("\u274c " + (e.message||"Login failed")); }
}

// ===== LOGOUT =====
async function doLogout(){
  stopGPS();
  await auth.signOut();
}

// ===== LOAD USER DATA =====
async function loadUserData(){
  if(!currentUser) return;
  const snap = await db.collection("users").doc(currentUser.uid).get();
  if(!snap.exists){ showToast("Profile not found"); return; }
  const d = snap.data();
  S = {
    wallet: d.wallet||0, totalKm: d.totalKm||0, todayKm: d.todayKm||0,
    kmLimit: d.kmLimit||BASE_KM_LIMIT, referralCount: d.referralCount||0,
    gpsUnlocked: d.gpsUnlocked||false, refCode: d.refCode||"",
    upiId: d.upiId||"", name: d.name||"Walker"
  };

  const updates = { lastSeen: firebase.firestore.FieldValue.serverTimestamp() };
  if((d.lastDate||"") !== todayStr()){ updates.todayKm = 0; updates.lastDate = todayStr(); S.todayKm = 0; }
  await db.collection("users").doc(currentUser.uid).update(updates);

  renderUserUI();

  db.collection("users").doc(currentUser.uid).onSnapshot((doc) => {
    if(!doc.exists) return;
    const d2 = doc.data();
    S.wallet   = d2.wallet||0;   S.totalKm  = d2.totalKm||0;
    S.todayKm  = d2.todayKm||0;  S.kmLimit  = d2.kmLimit||BASE_KM_LIMIT;
    S.gpsUnlocked = d2.gpsUnlocked||false; S.referralCount = d2.referralCount||0;
    S.upiId    = d2.upiId||"";   S.name     = d2.name||"Walker";
    S.refCode  = d2.refCode||"";
    renderUserUI();
  });
}

function renderUserUI(){
  const ini = (S.name||"W").charAt(0).toUpperCase();
  document.getElementById("headerName").textContent    = S.name||"Walker";
  document.getElementById("headerAvatar").textContent  = ini;
  document.getElementById("walletAmt").textContent     = S.wallet.toFixed(2);
  document.getElementById("statTotalKm").textContent   = S.totalKm.toFixed(2);
  document.getElementById("statTodayKm").textContent   = S.todayKm.toFixed(2);
  document.getElementById("statRefs").textContent      = S.referralCount;
  document.getElementById("refCodeDisplay").textContent = S.refCode||"------";
  document.getElementById("totalRefCount").textContent  = S.referralCount;
  document.getElementById("kmUsedDisplay").textContent  = S.totalKm.toFixed(1);
  document.getElementById("kmLimitDisplay").textContent = S.kmLimit;
  const remaining = Math.max(0, S.kmLimit - S.totalKm);
  document.getElementById("kmRemainingDisplay").textContent = remaining.toFixed(1);
  document.getElementById("kmProgressFill").style.width = Math.min(100,(S.totalKm/S.kmLimit)*100) + "%";

  document.getElementById("profileAvatar").textContent  = ini;
  document.getElementById("profileName").textContent    = S.name;
  document.getElementById("profileEmail").textContent   = currentUser?.email||"";
  document.getElementById("profileUpi").textContent     = S.upiId||"Not set";
  document.getElementById("profileRefCode").textContent = S.refCode||"--";
  document.getElementById("profileRefs").textContent    = S.referralCount;
  document.getElementById("profileGpsStatus").textContent = S.gpsUnlocked?"\u2705 Unlocked":"\ud83d\udd12 Locked";
  document.getElementById("profileGpsStatus").style.color = S.gpsUnlocked?"var(--g3)":"var(--red)";

  document.getElementById("gpsLockedCard").classList.toggle("hidden",  S.gpsUnlocked);
  document.getElementById("gpsActiveCard").classList.toggle("hidden", !S.gpsUnlocked);

  // Update share link cache
  currentShareLink = buildShareLink(S.refCode);
}

// ===== BUILD SHARE LINK =====
function buildShareLink(code){
  return location.origin + location.pathname + (code ? "?ref=" + code : "");
}

// ===== GPS TRACKING =====
function startGPS(){
  if(!S.gpsUnlocked){ openPayModal(); return; }
  const remaining = (S.kmLimit||BASE_KM_LIMIT) - (S.totalKm||0);
  if(remaining <= 0){ showToast("\u26a0 150 KM limit reached. Refer friends for +300 km."); return; }
  if(!navigator.geolocation){ showToast("\u26a0 Geolocation not supported on this device."); return; }

  gpsRunning = true; gpsPaused = false;
  gpsSessionKm = 0; gpsPendingKm = 0;
  gpsLastPos = null; gpsLastTimestamp = 0;

  setGpsButtons(true);
  showToast("\ud83d\udccd GPS started \u2014 Walk and earn \u20b92/km", 2500);
  document.getElementById("gpsDot").classList.add("running");
  document.getElementById("gpsStatusText").textContent = "Running";

  gpsWatchId = navigator.geolocation.watchPosition(
    onGpsUpdate,
    (err) => { showToast("\u26a0 GPS error: " + err.message); stopGPS(); },
    { enableHighAccuracy:true, maximumAge:5000, timeout:15000 }
  );
}

function onGpsUpdate(pos){
  if(!gpsRunning || gpsPaused) return;
