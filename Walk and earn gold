<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no"/>
<title>Health is Wealth \u2014 Walk, Earn &amp; Win</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-auth-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-firestore-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-storage-compat.js"></script>
<style>
/* ===== CSS VARIABLES ===== */
:root{
  --g1:#071c10;--g2:#0d4a28;--g3:#12803e;--g4:#1ab358;
  --gold:#f0b429;--gold2:#fad369;--gold3:#8a6210;
  --bg:#f2faf5;--bg2:#e0f4ea;--bg3:#c8ead8;
  --surf:#fff;--bdr:#b8ddc8;--bdr2:#90c8a8;
  --txt:#061810;--txt2:#1a3828;--txt3:#2e6040;--txt4:#5a9070;
  --red:#e03030;--orange:#f07c20;
  --radius:14px;--radius2:20px;
  --shadow:0 4px 24px rgba(7,28,16,.10);
  --shadow2:0 8px 40px rgba(7,28,16,.16);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{width:100%;min-height:100%;background:var(--bg);font-family:'DM Sans',sans-serif;color:var(--txt);overflow-x:hidden}
button{cursor:pointer;font-family:inherit;border:none;outline:none}
input,select,textarea{font-family:inherit;outline:none}
a{color:inherit;text-decoration:none}
img{display:block;max-width:100%}

/* ===== UTILITY ===== */
.hidden{display:none!important}
.bold{font-weight:700}
.center{text-align:center}
.green{color:var(--g3)}
.gold{color:var(--gold3)}
.red{color:var(--red)}
.small{font-size:.82rem}
.flex{display:flex;align-items:center}
.flex-col{display:flex;flex-direction:column}
.gap4{gap:4px}.gap8{gap:8px}.gap12{gap:12px}.gap16{gap:16px}
.mt8{margin-top:8px}.mt12{margin-top:12px}.mt16{margin-top:16px}.mt20{margin-top:20px}
.w100{width:100%}
.ellipsis{overflow:hidden;text-overflow:ellipsis;white-space:nowrap}

/* ===== SPLASH ===== */
#splash{
  position:fixed;inset:0;z-index:9999;
  background:linear-gradient(160deg,var(--g1) 0%,var(--g2) 60%,var(--g3) 100%);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:18px;
}
.splash-logo{
  width:88px;height:88px;border-radius:28px;
  background:linear-gradient(145deg,var(--gold2),var(--gold));
  display:flex;align-items:center;justify-content:center;
  font-size:2.8rem;
  box-shadow:0 0 0 8px rgba(240,180,41,.18),0 8px 40px rgba(0,0,0,.4);
  animation:logoPop .6s cubic-bezier(.34,1.56,.64,1) both;
}
@keyframes logoPop{from{transform:scale(0) rotate(-20deg);opacity:0}to{transform:scale(1) rotate(0);opacity:1}}
.splash-title{
  font-family:'Playfair Display',serif;font-size:2.1rem;font-weight:800;
  color:#fff;text-align:center;letter-spacing:-.5px;
  animation:fadeUp .5s .3s both;
}
.splash-sub{color:rgba(255,255,255,.65);font-size:.95rem;animation:fadeUp .5s .4s both;}
.splash-dots{display:flex;gap:8px;margin-top:10px;}
.splash-dot{
  width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.35);
  animation:dotPulse 1s infinite alternate;
}
.splash-dot:nth-child(2){animation-delay:.2s}
.splash-dot:nth-child(3){animation-delay:.4s}
@keyframes dotPulse{to{background:rgba(255,255,255,.9);transform:scale(1.3)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}

/* ===== AUTH SCREEN ===== */
#authScreen{
  min-height:100vh;background:linear-gradient(160deg,var(--g1) 0%,var(--g2) 55%,var(--bg3) 100%);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  padding:20px;gap:0;
}
.auth-header{text-align:center;margin-bottom:28px;}
.auth-logo{
  width:64px;height:64px;border-radius:20px;
  background:linear-gradient(145deg,var(--gold2),var(--gold));
  display:flex;align-items:center;justify-content:center;font-size:2rem;
  margin:0 auto 14px;box-shadow:0 4px 24px rgba(240,180,41,.4);
}
.auth-title{font-family:'Playfair Display',serif;font-size:1.8rem;color:#fff;font-weight:800}
.auth-sub{color:rgba(255,255,255,.6);font-size:.9rem;margin-top:4px}
.auth-card{
  background:var(--surf);border-radius:var(--radius2);padding:26px 22px;
  width:100%;max-width:400px;box-shadow:var(--shadow2);
}
.auth-tabs{display:flex;background:var(--bg2);border-radius:10px;padding:3px;margin-bottom:22px;}
.auth-tab{
  flex:1;padding:9px;border-radius:8px;font-size:.9rem;font-weight:600;
  background:transparent;color:var(--txt4);transition:.2s;
}
.auth-tab.active{background:var(--surf);color:var(--g3);box-shadow:0 2px 8px rgba(7,28,16,.1)}
.field-group{margin-bottom:14px;}
.field-label{font-size:.82rem;font-weight:600;color:var(--txt3);margin-bottom:5px;}
.field-input{
  width:100%;padding:12px 14px;border:1.5px solid var(--bdr);border-radius:10px;
  font-size:.95rem;background:var(--bg);color:var(--txt);
  transition:border-color .2s;
}
.field-input:focus{border-color:var(--g3)}
.field-input::placeholder{color:var(--txt4);opacity:.7}
.btn-primary{
  width:100%;padding:14px;border-radius:11px;
  background:linear-gradient(135deg,var(--g3),var(--g2));
  color:#fff;font-size:1rem;font-weight:700;
  box-shadow:0 4px 16px rgba(18,128,62,.35);
  transition:transform .15s,box-shadow .15s;
}
.btn-primary:active{transform:scale(.97)}
.btn-gold{
  width:100%;padding:14px;border-radius:11px;
  background:linear-gradient(135deg,var(--gold),var(--gold3));
  color:#fff;font-size:1rem;font-weight:700;
  box-shadow:0 4px 16px rgba(240,180,41,.35);
  transition:transform .15s,box-shadow .15s;
}
.btn-gold:active{transform:scale(.97)}
.auth-note{font-size:.8rem;color:var(--txt4);text-align:center;margin-top:14px;}

/* ===== MAIN APP ===== */
#userApp{display:none;flex-direction:column;min-height:100vh;padding-bottom:72px}
.app-header{
  background:linear-gradient(135deg,var(--g1) 0%,var(--g2) 100%);
  padding:52px 18px 18px;
  position:sticky;top:0;z-index:100;
}
.app-header-row{display:flex;align-items:center;justify-content:space-between;}
.app-greeting{color:rgba(255,255,255,.6);font-size:.82rem;font-weight:500}
.app-name{color:#fff;font-size:1.15rem;font-weight:700;margin-top:1px}
.app-avatar{
  width:40px;height:40px;border-radius:50%;
  background:linear-gradient(145deg,var(--gold2),var(--gold));
  display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:1.1rem;color:var(--g1);
  flex-shrink:0;
}
.app-content{flex:1;padding:0 14px;margin-top:16px;}

/* ===== WALLET CARD ===== */
.wallet-card{
  background:linear-gradient(145deg,var(--g2),var(--g1));
  border-radius:var(--radius2);padding:22px 20px;
  box-shadow:var(--shadow2);margin-bottom:18px;
  position:relative;overflow:hidden;
}
.wallet-card::before{
  content:'';position:absolute;top:-30px;right:-30px;
  width:140px;height:140px;border-radius:50%;
  background:rgba(26,179,88,.12);
}
.wallet-card::after{
  content:'';position:absolute;bottom:-40px;left:-20px;
  width:100px;height:100px;border-radius:50%;
  background:rgba(240,180,41,.08);
}
.wallet-label{color:rgba(255,255,255,.55);font-size:.8rem;font-weight:500;letter-spacing:.5px;text-transform:uppercase}
.wallet-amount{
  color:#fff;font-family:'Playfair Display',serif;
  font-size:2.4rem;font-weight:800;margin:4px 0;line-height:1;
}
.wallet-sub{color:rgba(255,255,255,.45);font-size:.78rem}
.wallet-actions{display:flex;gap:10px;margin-top:18px;}
.wallet-btn{
  flex:1;padding:11px 8px;border-radius:10px;font-size:.85rem;font-weight:700;
  transition:transform .15s;
}
.wallet-btn:active{transform:scale(.96)}
.wbtn-withdraw{background:var(--gold);color:var(--g1)}
.wbtn-history{background:rgba(255,255,255,.12);color:#fff;border:1px solid rgba(255,255,255,.2)}
.wallet-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-top:12px;}
.wstat{background:rgba(255,255,255,.08);border-radius:10px;padding:10px 8px;text-align:center}
.wstat-val{color:#fff;font-weight:700;font-size:1rem}
.wstat-lbl{color:rgba(255,255,255,.45);font-size:.7rem;margin-top:2px}

/* ===== SECTION TITLE ===== */
.sec-title{font-size:.78rem;font-weight:700;color:var(--txt4);letter-spacing:.8px;text-transform:uppercase;margin-bottom:10px}

/* ===== GPS CARD ===== */
.gps-card{
  background:var(--surf);border-radius:var(--radius2);
  padding:18px;box-shadow:var(--shadow);margin-bottom:18px;
  border:1.5px solid var(--bdr);
}
.gps-locked{
  background:linear-gradient(135deg,var(--bg2),var(--bg3));
  border-radius:var(--radius2);padding:20px;text-align:center;
  margin-bottom:18px;border:1.5px dashed var(--bdr2);
}
.gps-lock-icon{font-size:2.2rem;margin-bottom:8px}
.gps-lock-title{font-weight:700;font-size:1rem;color:var(--txt2)}
.gps-lock-desc{font-size:.83rem;color:var(--txt4);margin-top:4px;line-height:1.5}
.gps-price{
  font-size:1.5rem;font-weight:800;color:var(--g3);
  font-family:'Playfair Display',serif;margin:10px 0;
}
.btn-unlock{
  padding:13px 28px;border-radius:11px;
  background:linear-gradient(135deg,var(--g3),var(--g2));
  color:#fff;font-size:.95rem;font-weight:700;
  box-shadow:0 4px 16px rgba(18,128,62,.3);
}
.gps-active-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.gps-status{
  display:flex;align-items:center;gap:6px;
  font-size:.82rem;font-weight:600;
}
.gps-dot{width:8px;height:8px;border-radius:50%;background:var(--red)}
.gps-dot.running{background:var(--g4);animation:gpsPulse 1s infinite alternate}
@keyframes gpsPulse{to{box-shadow:0 0 0 4px rgba(26,179,88,.25)}}
.gps-stats{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
.gps-stat{
  background:var(--bg2);border-radius:10px;padding:12px;text-align:center;
}
.gps-stat-val{font-size:1.3rem;font-weight:800;color:var(--g3);font-family:'Playfair Display',serif}
.gps-stat-lbl{font-size:.72rem;color:var(--txt4);margin-top:2px;font-weight:500}
.gps-progress{margin-bottom:14px}
.progress-bar{height:8px;background:var(--bg3);border-radius:4px;overflow:hidden;margin-top:6px}
.progress-fill{height:100%;background:linear-gradient(90deg,var(--g4),var(--g3));border-radius:4px;transition:width .5s}
.gps-controls{display:flex;gap:8px}
.gps-btn{
  flex:1;padding:12px;border-radius:10px;font-size:.88rem;font-weight:700;
  transition:transform .15s;
}
.gps-btn:active{transform:scale(.96)}
.gbtn-start{background:linear-gradient(135deg,var(--g4),var(--g3));color:#fff}
.gbtn-pause{background:linear-gradient(135deg,var(--gold),var(--gold3));color:#fff}
.gbtn-stop{background:rgba(224,48,48,.1);color:var(--red);border:1.5px solid rgba(224,48,48,.2)}

/* ===== REFER CARD ===== */
.refer-card{
  background:linear-gradient(145deg,var(--g2),var(--g1));
  border-radius:var(--radius2);padding:18px;
  box-shadow:var(--shadow2);margin-bottom:18px;
}
.refer-title{color:#fff;font-weight:700;font-size:1rem}
.refer-sub{color:rgba(255,255,255,.55);font-size:.82rem;margin-top:3px}
.refer-code-box{
  background:rgba(255,255,255,.1);border-radius:10px;
  padding:12px 14px;margin:12px 0;
  display:flex;align-items:center;justify-content:space-between;
}
.refer-code{color:var(--gold2);font-size:1.05rem;font-weight:800;letter-spacing:2px;font-family:monospace}
.btn-copy{
  padding:6px 12px;border-radius:7px;
  background:rgba(255,255,255,.15);color:#fff;
  font-size:.8rem;font-weight:600;
}
.refer-perks{display:flex;gap:8px;margin-top:4px}
.refer-perk{
  flex:1;background:rgba(255,255,255,.07);border-radius:8px;
  padding:9px;text-align:center;
}
.perk-val{color:var(--gold2);font-weight:800;font-size:.95rem}
.perk-lbl{color:rgba(255,255,255,.45);font-size:.7rem;margin-top:2px}

/* ===== INFO CARDS ROW ===== */
.info-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:18px}
.info-card{
  background:var(--surf);border-radius:var(--radius);
  padding:14px;box-shadow:var(--shadow);border:1.5px solid var(--bdr);
}
.info-icon{font-size:1.5rem;margin-bottom:6px}
.info-val{font-size:1.1rem;font-weight:800;color:var(--txt2)}
.info-lbl{font-size:.73rem;color:var(--txt4);margin-top:2px}

/* ===== HOW IT WORKS ===== */
.how-card{
  background:var(--surf);border-radius:var(--radius2);
  padding:18px;box-shadow:var(--shadow);margin-bottom:18px;
  border:1.5px solid var(--bdr);
}
.how-step{display:flex;align-items:flex-start;gap:12px;padding:8px 0;border-bottom:1px solid var(--bg2)}
.how-step:last-child{border-bottom:none}
.how-num{
  width:28px;height:28px;border-radius:50%;
  background:linear-gradient(135deg,var(--g4),var(--g3));
  color:#fff;font-weight:800;font-size:.82rem;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.how-text{font-size:.87rem;color:var(--txt2);line-height:1.5;padding-top:4px}
.how-text b{color:var(--g3)}

/* ===== PRIZES SECTION ===== */
.prizes-banner{
  background:linear-gradient(145deg,#1a0a00,#4a1a00,#8a3a00);
  border-radius:var(--radius2);padding:18px;
  box-shadow:0 8px 32px rgba(240,180,41,.25);
  margin-bottom:18px;position:relative;overflow:hidden;
}
.prizes-banner::before{
  content:'';position:absolute;top:-20px;right:-20px;
  width:120px;height:120px;border-radius:50%;
  background:rgba(240,180,41,.12);
}
.prizes-banner::after{
  content:'';position:absolute;bottom:-30px;left:-10px;
  width:80px;height:80px;border-radius:50%;
  background:rgba(255,255,255,.05);
}
.prizes-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.prizes-title{color:#fff;font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:800}
.no-limit-badge{
  background:linear-gradient(135deg,var(--gold),var(--gold3));
  color:#fff;font-size:.65rem;font-weight:800;
  padding:3px 9px;border-radius:20px;letter-spacing:.5px;text-transform:uppercase;
}
.prize-item{
  display:flex;align-items:center;gap:12px;
  background:rgba(255,255,255,.07);border-radius:12px;
  padding:12px;margin-bottom:8px;
  border:1px solid rgba(240,180,41,.2);
}
.prize-item:last-child{margin-bottom:0}
.prize-rank-badge{
  width:36px;height:36px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;
  font-size:1.4rem;flex-shrink:0;
}
.prize-rank-1{background:linear-gradient(135deg,#ffd700,#b8860b)}
.prize-rank-2{background:linear-gradient(135deg,#c0c0c0,#808080)}
.prize-rank-3{background:linear-gradient(135deg,#cd7f32,#8b4513)}
.prize-info{flex:1}
.prize-name{color:#fff;font-weight:800;font-size:.95rem}
.prize-desc{color:rgba(255,255,255,.5);font-size:.73rem;margin-top:2px}
.prize-rank-label{
  font-size:.72rem;font-weight:800;
  padding:3px 9px;border-radius:20px;
}
.rank-1-label{background:rgba(255,215,0,.2);color:#ffd700}
.rank-2-label{background:rgba(192,192,192,.2);color:#c0c0c0}
.rank-3-label{background:rgba(205,127,50,.2);color:#cd7f32}

/* ===== BOTTOM NAV ===== */
#bnav{
  position:fixed;bottom:0;left:0;right:0;z-index:200;
  background:var(--surf);border-top:1px solid var(--bdr);
  display:flex;padding:8px 0 env(safe-area-inset-bottom);
  box-shadow:0 -4px 20px rgba(7,28,16,.08);
}
.bnav-item{
  flex:1;display:flex;flex-direction:column;align-items:center;
  gap:3px;padding:4px 0;
  font-size:.65rem;font-weight:600;color:var(--txt4);
  transition:color .2s;background:transparent;
}
.bnav-item.active{color:var(--g3)}
.bnav-icon{font-size:1.35rem;line-height:1}

/* ===== TABS ===== */
.tab-content{display:none}
.tab-content.active{display:block}

/* ===== HISTORY LIST ===== */
.history-item{
  background:var(--surf);border-radius:var(--radius);
  padding:14px;box-shadow:var(--shadow);margin-bottom:8px;
  border:1.5px solid var(--bdr);
  display:flex;align-items:center;justify-content:space-between;
}
.history-left{}
.history-type{font-weight:700;font-size:.9rem;color:var(--txt2)}
.history-date{font-size:.75rem;color:var(--txt4);margin-top:2px}
.history-amount{font-weight:800;font-size:1rem;color:var(--g3)}
.history-amount.minus{color:var(--red)}
.empty-state{
  text-align:center;padding:40px 20px;color:var(--txt4);
}
.empty-icon{font-size:2.5rem;margin-bottom:10px}

/* ===== UPI SHEET ===== */
#upiSheet{
  position:fixed;bottom:-100%;left:0;right:0;z-index:500;
  background:var(--surf);border-radius:20px 20px 0 0;
  padding:24px 20px 32px;
  transition:bottom .35s cubic-bezier(.4,0,.2,1);
  box-shadow:0 -8px 40px rgba(7,28,16,.18);
}
#upiSheet.open{bottom:0}
.sheet-handle{width:38px;height:4px;background:var(--bdr2);border-radius:2px;margin:0 auto 20px}
.sheet-title{font-size:1.05rem;font-weight:800;color:var(--txt);margin-bottom:18px;text-align:center}
.upi-balance{
  background:var(--bg2);border-radius:12px;padding:14px;
  text-align:center;margin-bottom:16px;
}
.upi-bal-lbl{font-size:.8rem;color:var(--txt4);font-weight:500}
.upi-bal-val{font-size:1.8rem;font-weight:800;color:var(--g3);font-family:'Playfair Display',serif}
.upi-min-note{font-size:.75rem;color:var(--txt4);margin-top:4px}
.sheet-overlay{position:fixed;inset:0;z-index:499;background:rgba(0,0,0,.4);display:none}
.sheet-overlay.open{display:block}

/* ===== PAYMENT MODAL ===== */
#payModal{
  position:fixed;inset:0;z-index:600;
  display:none;align-items:flex-end;justify-content:center;
}
#payModal.open{display:flex}
.pay-overlay{position:absolute;inset:0;background:rgba(0,0,0,.5)}
.pay-card{
  position:relative;z-index:1;
  background:var(--surf);border-radius:20px 20px 0 0;
  padding:24px 20px 32px;width:100%;
  max-height:90vh;overflow-y:auto;
}
.pay-title{font-size:1.1rem;font-weight:800;margin-bottom:6px;text-align:center}
.pay-sub{font-size:.84rem;color:var(--txt4);text-align:center;margin-bottom:20px;line-height:1.5}
.pay-amount-box{
  background:linear-gradient(135deg,var(--g3),var(--g2));
  border-radius:14px;padding:16px;text-align:center;margin-bottom:18px;
}
.pay-amount-lbl{color:rgba(255,255,255,.6);font-size:.78rem;font-weight:500}
.pay-amount-val{color:#fff;font-size:2rem;font-weight:800;font-family:'Playfair Display',serif}
.pay-upi-box{
  background:var(--bg2);border-radius:12px;padding:14px;
  margin-bottom:16px;text-align:center;
}
.pay-upi-lbl{font-size:.78rem;color:var(--txt4);font-weight:500}
.pay-upi-id{font-size:1.05rem;font-weight:800;color:var(--g2);letter-spacing:.5px;margin-top:4px;font-family:monospace}
.pay-steps{font-size:.82rem;color:var(--txt3);line-height:2;margin-bottom:16px}
.pay-steps span{font-weight:700;color:var(--g3)}
.pay-confirm-note{
  background:linear-gradient(135deg,rgba(240,180,41,.12),rgba(240,180,41,.06));
  border:1px solid rgba(240,180,41,.3);border-radius:10px;
  padding:12px;font-size:.82rem;color:var(--gold3);
  text-align:center;margin-bottom:14px;line-height:1.5;
}
.btn-close-pay{
  width:100%;padding:12px;border-radius:10px;
